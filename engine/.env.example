# RPC endpoint for the chain where ConfidentialExecutionEngine is deployed
RPC_URL=http://127.0.0.1:8545

# Private key of the engine signer (no 0x prefix or with 0x both work)
PRIVATE_KEY=your_private_key_here

# ConfidentialExecutionEngine contract address
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Chain ID (e.g. 31337 for Hardhat, 11155111 for Sepolia)
CHAIN_ID=31337

# Block confirmations before processing WorkflowCreated (default 2)
MIN_CONFIRMATIONS=2

# Max retries for finalizeExecution tx (default 3)
MAX_RETRIES=3

# Comma-separated creator addresses allowed to create workflows (empty = no restriction)
WORKFLOW_CREATOR_ALLOWLIST=0x1234567890123456789012345678901234567890

# Module execution timeout in ms (default 15000)
EXECUTION_TIMEOUT_MS=15000

# CRA Confidential HTTP (Chainlink)
CRA_WORKFLOW_URL=https://example.com/cra
API_KEY_SECRET_NAME=api-key
AES_ENCRYPTION_KEY_SECRET_NAME=aes-encryption-key
# For local simulation, set actual values (32-byte AES key as 64 hex chars):
# ENGINE_API_KEY=your-api-key
# ENGINE_AES_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
